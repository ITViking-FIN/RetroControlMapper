# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# Virtualenvs
.venv/
venv/
env/

# RetroBat config backups (created on first edit per day)
*.bak.rbcf.*

# Runtime state — machine-specific, regenerated
controller_sync.log
sync_manifest.json

# Arcade controls cache — fetched from yo1dog/controls-dat-json on
# first arcade-system lookup, ~5MB total. Regenerable; not source.
data/arcade_controls.json
data/controls.json
data/controls_buttons.json
data/arcade_controls.meta.json

# Manual ingestion artifacts (v0.1.4 manual-research pipeline) —
# all regenerable from the user's local Manual_Package.7z and from
# Flaresolverr-routed online lookups. Some files are large (~5MB JSON
# index, multi-GB cached PDF tree).
data/manual_archive_index.json
data/manual_archive_index.raw.txt
data/manuals/
data/manuals_online/
data/manuals_online_cache.json

# Per-machine path to the user's Manual_Package.7z. Contains a single
# absolute path; resolved by manual_local.py at runtime. Different on
# every install, never source.
data/manual_archive_path.txt

# Local Claude Code settings (project agents are tracked; personal overrides aren't)
.claude/settings.local.json

# IDE / editor
.vscode/
.idea/
*.swp
*~

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Packaging output (PyInstaller builds — the .exe and intermediate cache)
build/
dist/

# Research scratchpads — agents stage downloaded source for inspection here
.tmp_research/

# Stray pip --target output that lands in the project dir
Lib/

# Per-release notes file extracted from CHANGELOG for `gh release create`
RELEASE_NOTES_v*.md

# Claude-internal scaffolding — orientation, decision ledger, agent
# reports. Useful while building, must NOT be in the public source tree.
# Per user rule 2026-05-05: only valid project files allowed in repo.
CLAUDE.md
DECISIONS.md
OVERNIGHT_REPORT.md
OVERNIGHT_QUESTIONS.md
CLEANUP_REPORT.md
docs/V010_QA_REPORT.md
.claude/
