build/
dist/

# Research scratchpads — agents stage downloaded source for inspection here
.tmp_research/

# Stray pip --target output that lands in the project dir
Lib/

# Per-release notes file extracted from CHANGELOG for `gh release create`
RELEASE_NOTES_v*.md

