# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# Virtualenvs
.venv/
venv/
env/

# RetroBat config backups (created on first edit per day)
*.bak.rbcf.*

# Runtime state — machine-specific, regenerated
controller_sync.log
sync_manifest.json

# Arcade controls cache — fetched from yo1dog/controls-dat-json on
# first arcade-system lookup, ~5MB total. Regenerable; not source.
data/arcade_controls.json
data/controls.json
data/controls_buttons.json
data/arcade_controls.meta.json

# Manual ingestion artifacts (v0.1.4 manual-research pipeline) —
# all regenerable from the user's local Manual_Package.7z and from
# Flaresolverr-routed online lookups. Some files are large (~5MB JSON
# index, multi-GB cached PDF tree).
data/manual_archive_index.json
data/manual_archive_index.raw.txt
data/manuals/
data/manuals_online/
data/manuals_online_cache.json

# Per-machine path to the user's Manual_Package.7z. Contains a single
# absolute path; resolved by manual_local.py at runtime. Different on
# every install, never source.
data/manual_archive_path.txt

# Bindings DB working tree — built by build_bindings_db.py from the
# user's local Manual_Package. The shippable artifact ends up under
# release/ (tracked separately); the working tree here is per-machine
# extraction state and shouldn't go into source.
data/bindings_db/

# Per-user customised bindings + community-submission queue. Local
# state, never source. The submit flow (when wired) will push these
# through the existing community-submission plumbing.
data/bindings_user/
data/bindings_user_submission_queue/

# build log
data/build_bindings_db.log

# Cascade pipeline runner — per-machine paths to temp logs, lives
# in the repo for convenience but is not source.
run_full_pipeline.sh
memory_watch.sh
data/cascade.log
data/upgrade.log
data/pipeline.log
data/final-stats.txt

# LLM learning-loop state (v0.2 spike) — per-machine accumulated
# examples + diagnostic logs. The pool grows over runs; never source.
data/llm_few_shot.json
data/llm_rejections.jsonl
data/llm_uncertain.jsonl
data/llm_calls.jsonl
data/llm_learning_curve.html
data/llm_hybrid_feed.log
data/llm_hybrid_feed_run.log
data/cascade_resumed.log
data/pass5_only.log
data/pass5_after_v3.log
data/pass1_v2.log
data/pass1_v3.log

# OCR text cache — keyed by (pdf path, PSM, lang, DPI). Avoids re-running
# tesseract across multi-pass extraction. Per-machine, regenerable.
data/.ocr_cache/

# Local Claude Code settings (project agents are tracked; personal overrides aren't)
.claude/settings.local.json

# IDE / editor
.vscode/
.idea/
*.swp
*~

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Packaging output (PyInstaller builds — the .exe and intermediate cache)
build/
dist/

# Research scratchpads — agents stage downloaded source for inspection here
.tmp_research/

# Stray pip --target output that lands in the project dir
Lib/

# Per-release notes file extracted from CHANGELOG for `gh release create`
RELEASE_NOTES_v*.md

# Claude-internal scaffolding — orientation, decision ledger, agent
# reports. Useful while building, must NOT be in the public source tree.
# Per user rule 2026-05-05: only valid project files allowed in repo.
CLAUDE.md
DECISIONS.md
OVERNIGHT_REPORT.md
OVERNIGHT_QUESTIONS.md
CLEANUP_REPORT.md
docs/V010_QA_REPORT.md
.claude/
